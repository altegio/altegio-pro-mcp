{
  "name": "@altegio/mcp-server-pro",
  "version": "1.0.0",
  "description": "Professional B2B MCP (Model Context Protocol) server for Altegio.Pro business management and admin operations",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "altegio",
    "altegio-pro",
    "b2b",
    "business-management",
    "salon-management",
    "admin",
    "booking",
    "api",
    "ai",
    "llm",
    "claude"
  ],
  "homepage": "https://github.com/altegio/altegio-pro-mcp#readme",
  "bugs": {
    "url": "https://github.com/altegio/altegio-pro-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/altegio/altegio-pro-mcp.git"
  },
  "license": "MIT",
  "author": {
    "name": "Yuri Petrov",
    "email": "y.petrov@yclients.tech"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "altegio-mcp": "./dist/index.js",
    "altegio-mcp-http": "./dist/http-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http-server.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:spec": "jest --testPathPatterns=spec-compliance --no-coverage --verbose",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.1",
    "@types/swagger-schema-official": "^2.0.25",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
